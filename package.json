{
  "name": "worldforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local GPU-rendered deep-zoom world map builder (Milestone 1: terrain foundation)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/generate-sw.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "app": "npm run build && vite preview --host 0.0.0.0 --port 4173 --strictPort"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
